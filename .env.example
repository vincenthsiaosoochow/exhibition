# ===== 前端环境变量 =====

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# NEXT_PUBLIC_API_URL: 后端 FastAPI 服务地址（不带尾部斜杠）
# 本地开发：http://localhost:8000
# Zeabur 部署：https://your-backend-service.zeabur.app
NEXT_PUBLIC_API_URL="http://localhost:8000"

# ===== 后端环境变量（在 backend/ 服务中配置）=====

# DATABASE_URL: MySQL 连接字符串
# 格式：mysql+pymysql://user:password@host:port/dbname
# Zeabur 中可使用变量引用：mysql+pymysql://${MYSQL_USERNAME}:${MYSQL_PASSWORD}@${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DATABASE}
DATABASE_URL="mysql+pymysql://root:root@localhost:3306/exhibition"

# ALLOWED_ORIGINS: 允许跨域访问的前端域名（逗号分隔）
ALLOWED_ORIGINS="http://localhost:3000"
